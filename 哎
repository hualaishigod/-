<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: #e8e8e8;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
  }
  canvas { display: block; }
</style>
</head>
<body>
<canvas id="c"></canvas>
<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

const W = 938, H = 274;
canvas.width = W;
canvas.height = H;
canvas.style.width = Math.min(938, window.innerWidth * 0.95) + 'px';
canvas.style.height = 'auto';

const avatarImg = new Image();
avatarImg.src = 'data:image/png;base64,';

// Positions from image (938x274):
// Avatar: top-left corner, ~85x85
const AV = { x: 8, y: 8, w: 82, h: 82 };

// Original positions of the three parts in the image
// 艹  (grass top radical) — top, center ~(265, 68)
// 口  (square/mouth) — left ~(168, 145)
// ×   (cross/×) — right of 口 ~(248, 178)
const CAO_ORIG = { x: 265, y: 72 };
const KOU_ORIG = { x: 168, y: 148 };
const X_ORIG   = { x: 252, y: 183 };

// Final "苦" composed layout — vertically centered ~x=210
const CX = 210;
const CAO_FINAL = { x: CX, y: 82 };
const SHI_FINAL = { x: CX, y: 135 };
const KOU_FINAL = { x: CX, y: 192 };

const SZ = 56; // stroke element size

// Timeline
const P1 = 0.55;   // phase1 end (口 grow + × rotate)
const P2 = 1.55;   // phase2 end (elements move to stack)
const P3 = 3.0;    // total loop
const HOLD = P3;

function easeOut(t) { return 1 - Math.pow(1-t, 3); }
function easeInOut(t) { return t<0.5 ? 2*t*t : -1+(4-2*t)*t; }
function lerp(a,b,t) { return a+(b-a)*t; }

let t0 = null;

function drawCao(x, y, sz, alpha=1) {
  ctx.save();
  ctx.translate(x, y);
  ctx.globalAlpha = alpha;
  ctx.strokeStyle = '#1a1a1a';
  ctx.lineWidth = sz * 0.17;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  const w = sz * 0.44;
  const bar = -sz * 0.05;      // horizontal bar y position (lower, mid-area)
  const vtop = -sz * 0.38;     // verticals start ABOVE the bar
  const vbot = sz * 0.32;      // verticals end below
  // horizontal bar
  ctx.beginPath(); ctx.moveTo(-w, bar); ctx.lineTo(w, bar); ctx.stroke();
  // left upright (starts above bar)
  ctx.beginPath(); ctx.moveTo(-w*0.55, vtop); ctx.lineTo(-w*0.55, vbot); ctx.stroke();
  // right upright (starts above bar)
  ctx.beginPath(); ctx.moveTo(w*0.55, vtop); ctx.lineTo(w*0.55, vbot); ctx.stroke();
  ctx.restore();
}

function drawKou(x, y, sz, scale=1, alpha=1) {
  ctx.save();
  ctx.translate(x, y);
  ctx.scale(scale, scale);
  ctx.globalAlpha = alpha;
  ctx.strokeStyle = '#1a1a1a';
  ctx.lineWidth = sz * 0.17;
  ctx.lineJoin = 'round';
  const s = sz * 0.38;
  ctx.strokeRect(-s, -s, s*2, s*2);
  ctx.restore();
}

function drawCross(x, y, sz, rotation, alpha=1) {
  // rotation=PI/4 → ×, rotation=0 → 十
  ctx.save();
  ctx.translate(x, y);
  ctx.rotate(rotation);
  ctx.globalAlpha = alpha;
  ctx.strokeStyle = '#1a1a1a';
  ctx.lineWidth = sz * 0.19;
  ctx.lineCap = 'round';
  const arm = sz * 0.44;
  ctx.beginPath(); ctx.moveTo(-arm, 0); ctx.lineTo(arm, 0); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(0, -arm); ctx.lineTo(0, arm); ctx.stroke();
  ctx.restore();
}

function frame(ts) {
  if (!t0) t0 = ts;
  const el = ((ts - t0) / 1000) % P3;

  ctx.fillStyle = '#e8e8e8';
  ctx.fillRect(0, 0, W, H);

  // Avatar — always static
  ctx.save();
  const r = 10;
  ctx.beginPath();
  ctx.moveTo(AV.x+r, AV.y);
  ctx.arcTo(AV.x+AV.w, AV.y, AV.x+AV.w, AV.y+AV.h, r);
  ctx.arcTo(AV.x+AV.w, AV.y+AV.h, AV.x, AV.y+AV.h, r);
  ctx.arcTo(AV.x, AV.y+AV.h, AV.x, AV.y, r);
  ctx.arcTo(AV.x, AV.y, AV.x+AV.w, AV.y, r);
  ctx.closePath();
  ctx.clip();
  ctx.drawImage(avatarImg, 0, 0, AV.w, AV.h, AV.x, AV.y, AV.w, AV.h);
  ctx.restore();

  if (el < P1) {
    // Phase 1: 口 grows, × rotates to become 十, 艹 stays
    const p = easeOut(el / P1);

    drawCao(CAO_ORIG.x, CAO_ORIG.y, SZ);
    drawKou(KOU_ORIG.x, KOU_ORIG.y, SZ, lerp(1, 1.38, p));
    drawCross(X_ORIG.x, X_ORIG.y, SZ, lerp(Math.PI/4, 0, p));

  } else if (el < P2) {
    // Phase 2: all three move into vertical stack
    const p = easeInOut((el - P1) / (P2 - P1));

    const caoX = lerp(CAO_ORIG.x, CAO_FINAL.x, p);
    const caoY = lerp(CAO_ORIG.y, CAO_FINAL.y, p);
    drawCao(caoX, caoY, SZ);

    const shiX = lerp(X_ORIG.x, SHI_FINAL.x, p);
    const shiY = lerp(X_ORIG.y, SHI_FINAL.y, p);
    drawCross(shiX, shiY, SZ, 0);

    const kouX = lerp(KOU_ORIG.x, KOU_FINAL.x, p);
    const kouY = lerp(KOU_ORIG.y, KOU_FINAL.y, p);
    drawKou(kouX, kouY, SZ, lerp(1.38, 1.0, p));

  } else {
    // Phase 3: hold as 苦
    drawCao(CAO_FINAL.x, CAO_FINAL.y, SZ);
    drawCross(SHI_FINAL.x, SHI_FINAL.y, SZ, 0);
    drawKou(KOU_FINAL.x, KOU_FINAL.y, SZ, 1.0);
  }

  requestAnimationFrame(frame);
}

avatarImg.onload = () => requestAnimationFrame(frame);
setTimeout(() => { if (!t0) requestAnimationFrame(frame); }, 300);
</script>
</body>
</html>
